# weekly-digest environment configuration
# Copy this file to .env for local development. Real values are stored as GitHub Actions
# secrets in production — see docs/SETUP.md.

# ─── Google Calendar ────────────────────────────────────────────────────────────
# Created in Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# (Desktop app type). Consent screen must be PUBLISHED TO PRODUCTION to avoid
# 7-day refresh-token expiry.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Generated once locally via `python scripts/generate_calendar_token.py`
GOOGLE_REFRESH_TOKEN=

# Comma-separated list of calendar IDs to read. "primary" reads the authenticated
# account's main calendar. Other calendars use email-like IDs.
# Example: primary,shared.calendar.id@group.calendar.google.com
GOOGLE_CALENDAR_IDS=primary

# ─── Event sources ──────────────────────────────────────────────────────────────
TICKETMASTER_API_KEY=
SONGKICK_API_KEY=

# ─── Personalization (Claude) ───────────────────────────────────────────────────
# Used for the monthly preference profile and weekly event ranking. The deals
# section does not call Claude — it scrapes charlotteonthecheap.com's RSS feed.
ANTHROPIC_API_KEY=
# Optional model overrides — defaults are set in newsletter/config.py
# CLAUDE_PROFILE_MODEL=claude-haiku-4-5
# CLAUDE_RANKING_MODEL=claude-sonnet-4-6

# ─── Delivery (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
NEWSLETTER_FROM_EMAIL=newsletter@yourdomain.com
NEWSLETTER_TO_EMAILS=andrew.m.mahn@gmail.com,girlfriend@example.com

# ─── Location ───────────────────────────────────────────────────────────────────
# Defaults to Charlotte, NC if unset.
CITY_NAME=Charlotte
CITY_STATE=NC
CITY_LAT=35.2271
CITY_LON=-80.8431
TIMEZONE=America/New_York
